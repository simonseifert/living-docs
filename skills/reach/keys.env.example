# reach optional API keys. Copy to ~/.reach/keys.env and chmod 600.
# The keyless commands (web, repo-wiki, yt, rss, repo) work without any of these.
EXA_API_KEY=          # reach search (get a free key at exa.ai)
JINA_API_KEY=         # raises reach web / search rate limits (optional; keyless works)
FIRECRAWL_API_KEY=    # reach crawl (firecrawl.dev)
APIFY_TOKEN=          # reach instagram / reach reddit (apify.com)
GROQ_API_KEY=         # reach transcribe + /docs refresh cheap-model patching (console.groq.com)
DEEPSEEK_API_KEY=     # optional: /docs refresh --provider deepseek (platform.deepseek.com)
